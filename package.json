{
  "name": "@sledorze/cairn",
  "version": "0.1.0",
  "description": "Hierarchical documentation summary consolidation with content-hash freshness (clone/CI-proof) and dead-link checking. Agent-agnostic CLI; scaffolds guidance for Claude Code and GitHub Copilot.",
  "keywords": [
    "documentation",
    "summary",
    "markdown",
    "dead-links",
    "effect",
    "claude",
    "copilot",
    "agents"
  ],
  "license": "MIT",
  "author": "Stéphane Le Dorze",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sledorze/cairn.git"
  },
  "type": "module",
  "sideEffects": false,
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "cairn": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "schema"
  ],
  "scripts": {
    "bench": "vitest bench",
    "build": "pnpm run generate-schema && tsc -p tsconfig.build.json && pnpm run bundle-cli",
    "bundle-cli": "esbuild dist/cli.js --bundle --platform=node --format=esm --outfile=dist/cli.js --allow-overwrite --banner:js=\"import { createRequire as __cr } from 'module'; const require = __cr(import.meta.url);\"",
    "check": "tsx src/cli.ts check",
    "dev": "tsx src/cli.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "generate-schema": "tsx scripts/generate-schema.ts",
    "lint": "oxlint",
    "prepare": "lefthook install || true",
    "prepublishOnly": "pnpm build",
    "release": "changeset publish",
    "stamp": "tsx src/cli.ts check --summaries-only --stamp",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm check"
  },
  "dependencies": {
    "@effect/cli": "^0.76.0",
    "@effect/platform": "^0.97.0",
    "@effect/platform-node": "^0.108.0",
    "effect": "^3.22.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@types/node": "^26.1.1",
    "esbuild": "^0.28.1",
    "lefthook": "^2.1.0",
    "oxlint": "1.74.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "lefthook"
    ]
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
